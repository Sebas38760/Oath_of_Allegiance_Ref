#: Oath_of_Allegiance_Ref/achievements.cfg:85
msgid "Let the dwarvish adventure join your group."
msgstr "Permite que el aventuro enano se una a tu grupo."

#. [achievement], id=ooa13
#: Oath_of_Allegiance_Ref/achievements.cfg:91
msgid "Scenario 12: Where are my guards?"
msgstr "Escenario 12: ¿Dónde están mis guardias?"

#. [achievement], id=ooa13
#: Oath_of_Allegiance_Ref/achievements.cfg:92
msgid "Defeat Abbas without killing his guards."
msgstr "Derrota a Abbas sin matar a sus guardias."

#. [achievement], id=ooa14
#: Oath_of_Allegiance_Ref/achievements.cfg:98
msgid "Scenario 13: Like an Assassin"
msgstr "Escenario 13: Como un asesino"

#. [achievement], id=ooa14
#: Oath_of_Allegiance_Ref/achievements.cfg:99
msgid "Don't get caught once."
msgstr "No te dejes capturar ni una vez."

#. [achievement], id=ooa15
#: Oath_of_Allegiance_Ref/achievements.cfg:105
msgid "Scenario 13: Free like a Bir... Minotaur"
msgstr "Escenario 13: Libre como un Bir... Minotauro"

#. [achievement], id=ooa15
#: Oath_of_Allegiance_Ref/achievements.cfg:106
msgid "Free all Minotaurs from prison."
msgstr "Libera a todos los minotauros de la prisión."

#. [achievement], id=ooa16
#: Oath_of_Allegiance_Ref/achievements.cfg:112
msgid "Scenario 14: Bloodmaiden?"
msgstr "Escenario 14: ¿Doncella de sangre?"

#. [achievement], id=ooa16
#: Oath_of_Allegiance_Ref/achievements.cfg:113
msgid "Recruit the Bloodmaiden to your side."
msgstr "Recluta a la Doncella de Sangre a tu lado."

#. [achievement], id=ooa17
#: Oath_of_Allegiance_Ref/achievements.cfg:119
msgid "Scenario 14: A palm tree? No, a Wose again."
msgstr "Escenario 14: ¿Una palmera? No, un wose otra vez."

#. [achievement], id=ooa17
#: Oath_of_Allegiance_Ref/achievements.cfg:120
msgid "Recruit the hidden Wose."
msgstr "Recluta al wose oculto."

#. [achievement], id=ooa18
#: Oath_of_Allegiance_Ref/achievements.cfg:126
msgid "Scenario 14: Burn, baby, burn."
msgstr "Escenario 14: Quema, nena, quema."

#. [achievement], id=ooa18
#: Oath_of_Allegiance_Ref/achievements.cfg:127
msgid "Find the hidden fire sword."
msgstr "Encuentra la espada de fuego oculta."

#. [achievement], id=ooa19
#: Oath_of_Allegiance_Ref/achievements.cfg:133
msgid "Scenario 15: Cut the head of the snake."
msgstr "Escenario 15: Corta la cabeza de la serpiente."

#. [achievement], id=ooa19
#: Oath_of_Allegiance_Ref/achievements.cfg:134
msgid "Defeat all bandit leaders."
msgstr "Derrota a todos los líderes de bandidos."

#. [achievement], id=ooa20
#: Oath_of_Allegiance_Ref/achievements.cfg:140
msgid "Scenario 16: We are already prepared and ready."
msgstr "Escenario 16: Ya estamos preparados y listos."

#. [achievement], id=ooa20
#: Oath_of_Allegiance_Ref/achievements.cfg:141
msgid "Recruit units before talking to Maralek."
msgstr "Recluta unidades antes de hablar con Maralek."

#. [achievement], id=ooa21
#: Oath_of_Allegiance_Ref/achievements.cfg:148
msgid "Scenario 17: I expected a Scorpion."
msgstr "Escenario 17: Esperaba un escorpión."

#. [achievement], id=ooa21
#: Oath_of_Allegiance_Ref/achievements.cfg:149
msgid "Find the hidden GreenScarab."
msgstr "Encuentra el Escarabajo Verde oculto."

#. [achievement], id=ooa22
#: Oath_of_Allegiance_Ref/achievements.cfg:155
msgid "Scenario 18: Not even a message?"
msgstr "Escenario 18: ¿Ni siquiera un mensaje?"

#. [achievement], id=ooa22
#: Oath_of_Allegiance_Ref/achievements.cfg:156
msgid "Find the rock without any message."
msgstr "Encuentra la roca sin ningún mensaje."

#. [achievement], id=ooa23
#: Oath_of_Allegiance_Ref/achievements.cfg:162
msgid "Scenario 19: Leader first, then ..."
msgstr "Escenario 19: Líder primero, luego..."

#. [achievement], id=ooa23
#: Oath_of_Allegiance_Ref/achievements.cfg:163
msgid "Defeat Malykh first, before defeating Zebhan or Askyal."
msgstr "Derrota a Malykh primero, antes de derrotar a Zebhan o Askyal."

#. [achievement], id=ooa24
#: Oath_of_Allegiance_Ref/achievements.cfg:169
msgid "Scenario 21: ... Leader last."
msgstr "Escenario 21: ... Líder al final."

#. [achievement], id=ooa24
#: Oath_of_Allegiance_Ref/achievements.cfg:170
msgid "Defeat Malykh last."
msgstr "Derrota a Malykh al final."

