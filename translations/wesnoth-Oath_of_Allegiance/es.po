#. [campaign], id=Oath_of_Allegiance
#: Oath_of_Allegiance_Ref/_main.cfg:26
msgid ""
"Accompany Ilriel, an elvish druid of the Southwoods of Wesnoth, and take "
"part in an unforeseen and unintentional adventure that leads to lands far "
"away.\n"
"\n"
msgstr ""
"Acompaña a Ilriel, una druida elfa de los Bosques del Sur de Wesnoth, y "
"participa en una aventura imprevista e involuntaria que lleva a tierras "
"lejanas.\n"
"\n"

#. [campaign], id=Oath_of_Allegiance
#: Oath_of_Allegiance_Ref/_main.cfg:28
msgid "(Intermediate difficulty, 22 scenarios, 3 of them dialogue-only)"
msgstr "(Dificultad intermedia, 22 escenarios, 3 de ellos solo diálogos)"

